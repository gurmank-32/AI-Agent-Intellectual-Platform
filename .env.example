ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here
CHAT_PROVIDER=auto
EMBED_PROVIDER=gemini
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here
SMTP_EMAIL=optional_for_email_alerts
SMTP_PASSWORD=optional_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# RAG pipeline tuning
RAG_HYBRID_ENABLED=true
RAG_HYBRID_VECTOR_WEIGHT=0.6
RAG_RETRIEVAL_TOP_N=15
RAG_RERANK_TOP_K=5
RAG_LLM_RERANK_ENABLED=false
RAG_USE_LEGAL_CHUNKING=true
RAG_CROSS_JURISDICTION_MAX=8
RAG_MAX_CHUNKS_PER_SOURCE=2
RAG_MIN_INFORMATIVE_CHARS=220
